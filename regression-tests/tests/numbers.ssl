main ( cout : & Int ) (num : & Int) -> () =
    let x = Digits (Cons One (Cons Two (Cons Four Nil)))
    let y = Digits (Cons Five (Cons Five (Cons Zero Nil)))
    print cout (btos (eqDigits  x x))
    print cout (btos (eqDigits  x y))

        

        






        